# Django Settings
SECRET_KEY=your-django-secret-key-here
DEBUG=False
ALLOWED_HOSTS=scanwage-api.onrender.com

# Database Configuration
# For local SQLite development, leave DATABASE_URL empty or commented out.
# For Supabase production, fill with your Supabase connection string.
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres
DB_SSL_REQUIRE=True

# Automatic Superuser Creation on Build/Deploy
CREATE_SUPERUSER=True
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=your_secure_password_here

# Google Sheets Sync Configuration
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# GOOGLE_SERVICE_ACCOUNT_JSON='{"type": "service_account", ...}'
# GOOGLE_SHEETS_SPREADSHEET_ID=your_google_sheets_spreadsheet_id_here
